modules = ["nodejs-24"]

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 24605
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run build && npm run serve"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CalculateTrip"

[[workflows.workflow]]
name = "CalculateTrip"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "kill -9 $(lsof -ti:24605 2>/dev/null) 2>/dev/null; sleep 0.5; PORT=24605 node serve.js"
waitForPort = 24605

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm install && npm run build"]
run = ["node", "serve.js"]
