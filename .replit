modules = ["nodejs-24"]

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 24605
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run build && npm run serve"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "CalculateTrip"

[[workflows.workflow]]
name = "CalculateTrip"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run build && PORT=8080 npm run serve"
waitForPort = 8080

[deployment]
deploymentTarget = "static"
publicDir = "dist"
build = ["sh", "-c", "npm install && npm run build"]
