modules = ["nodejs-24"]

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 24605
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run build && npm run serve"

[deployment]
deploymentTarget = "static"
publicDir = "dist"
build = ["sh", "-c", "npm install && npm run build"]
