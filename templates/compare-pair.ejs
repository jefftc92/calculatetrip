<%
const aWins = a.ratings.overall >= b.ratings.overall
const winner = aWins ? a : b
const loser  = aWins ? b : a
const ratingRows = [
  { key: 'overall',      label: 'Overall Score' },
  { key: 'food',         label: 'Food & Dining' },
  { key: 'beach',        label: 'Beach' },
  { key: 'pool',         label: 'Pool' },
  { key: 'atmosphere',   label: 'Atmosphere' },
  { key: 'location',     label: 'Location' },
  { key: 'room',         label: 'Rooms' },
  { key: 'value',        label: 'Value for Money' },
  { key: 'cleanliness',  label: 'Cleanliness' },
  { key: 'service',      label: 'Service' },
  { key: 'sleepQuality', label: 'Sleep Quality' },
]
%>

<script type="application/ld+json">
<%- JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `${a.name} vs ${b.name} — All-Inclusive Resort Comparison 2025`,
  url: canonical,
  description: `Side-by-side comparison of ${a.name} and ${b.name}.`,
}) %>
</script>

<div class="bg-gradient-to-br from-ocean-950 via-ocean-900 to-ocean-800 px-4 sm:px-6 pt-8 pb-20">
  <div class="max-w-6xl mx-auto">
    <a href="/compare/" class="inline-flex items-center gap-1.5 font-sans text-xs text-ocean-400 hover:text-ocean-200 transition-colors mb-8">← All Comparisons</a>
    <p class="font-sans text-xs font-bold uppercase tracking-[0.2em] text-ocean-500 mb-2 text-center">Resort Comparison · 2025</p>
    <h1 id="comparison-title" class="font-serif text-3xl md:text-4xl font-bold text-white text-center mb-10 leading-tight">
      <%= a.name %>
      <span class="block font-sans font-normal text-ocean-500 text-xl my-2">vs</span>
      <%= b.name %>
    </h1>

    <div id="hero-strip" class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      <% [a, b].forEach((r, idx) => { %>
        <div class="rounded-2xl p-4 sm:p-5 border bg-white/5 border-white/10" data-slug="<%= r.slug %>">
          <a href="/resorts/<%= r.slug %>/" class="font-serif text-base sm:text-lg font-bold text-white hover:text-gold-300 transition-colors block leading-snug mb-1"><%= r.name %></a>
          <p class="font-sans text-xs text-ocean-400 mb-3"><%= r.country %> · <%= r.type === 'adults-only' ? 'Adults Only' : 'Family' %></p>
          <div class="font-serif text-4xl font-bold tabular-nums <%= scoreColor(r.ratings.overall) %>"><%= r.ratings.overall %></div>
          <div class="font-sans text-xs text-ocean-400 mt-0.5 mb-4"><%= scoreLabel(r.ratings.overall) %></div>
          <div class="flex flex-wrap gap-1 mb-4">
            <% r.amenities.forEach(am => { %>
              <span class="font-sans text-[10px] bg-white/10 text-ocean-200 px-2 py-0.5 rounded-full leading-tight"><%= am %></span>
            <% }) %>
          </div>
          <a href="<%= r.agodaLink %>" target="_blank" rel="noopener noreferrer sponsored" class="block font-sans text-sm font-semibold rounded-xl py-2.5 transition-colors text-center bg-gold-500 hover:bg-gold-600 text-white">Check Prices →</a>
        </div>
      <% }) %>
      <!-- Empty "Add Resort" slot -->
      <button type="button" id="add-resort-slot" class="rounded-2xl p-4 sm:p-5 border-2 border-dashed border-white/20 hover:border-gold-500/60 hover:bg-white/5 transition-colors flex flex-col items-center justify-center gap-2 min-h-[180px] text-ocean-300 hover:text-gold-300 col-span-2 sm:col-span-1">
        <span class="text-3xl">+</span>
        <span class="font-sans text-xs font-bold uppercase tracking-widest">Add Resort</span>
      </button>
    </div>
  </div>
</div>

<div class="max-w-6xl mx-auto px-4 sm:px-6 -mt-8 pb-16">

  <!-- Key differences (hidden when 3+ resorts) -->
  <div id="editorial-summary" class="bg-white border border-ocean-100 rounded-2xl shadow-card p-5 sm:p-7 mb-6">
    <p class="font-sans text-xs font-bold uppercase tracking-widest text-ocean-500 mb-1">Editorial Summary</p>
    <h2 class="font-serif text-xl font-bold text-ocean-950 mb-3">Key Differences</h2>
    <p class="font-sans text-sm text-ocean-700 leading-relaxed">
      <%= winner.name %> (<%= winner.ratings.overall %>/10) edges ahead of <%= loser.name %> (<%= loser.ratings.overall %>/10) overall, but both rank among the best all-inclusive resorts in the region.
      <% if (a.type !== b.type) { %>
        The most decisive factor is audience: <%= a.type === 'adults-only' ? a.name : b.name %> is adults-only, while <%= a.type === 'family' ? a.name : b.name %> welcomes families.
      <% } %>
    </p>
  </div>

  <!-- Ratings table -->
  <div id="ratings-table" class="bg-white rounded-2xl shadow-card overflow-hidden mb-6 border border-ocean-100">
    <div class="ratings-header grid grid-cols-[1fr_80px_80px] sm:grid-cols-[1fr_100px_100px] bg-ocean-950 text-white text-xs font-sans font-bold uppercase tracking-wider">
      <div class="px-4 sm:px-5 py-3.5">Category</div>
      <div class="py-3.5 text-center truncate px-1 text-ocean-300"><%= a.name.split(' ')[0] %></div>
      <div class="py-3.5 text-center truncate px-1 text-ocean-300"><%= b.name.split(' ')[0] %></div>
    </div>

    <!-- Booking row -->
    <div class="ratings-row grid grid-cols-[1fr_80px_80px] sm:grid-cols-[1fr_100px_100px] border-b border-ocean-50 bg-white">
      <div class="px-4 sm:px-5 py-3.5 font-sans text-sm text-ocean-700 font-semibold">Book Online</div>
      <div class="py-3 flex items-center justify-center">
        <a href="<%= a.agodaLink %>" target="_blank" rel="noopener noreferrer sponsored" class="inline-block font-sans text-[11px] font-bold uppercase tracking-wide bg-ocean-900 hover:bg-ocean-950 text-white px-3 py-1.5 rounded transition-colors">Book Now</a>
      </div>
      <div class="py-3 flex items-center justify-center">
        <a href="<%= b.agodaLink %>" target="_blank" rel="noopener noreferrer sponsored" class="inline-block font-sans text-[11px] font-bold uppercase tracking-wide bg-ocean-900 hover:bg-ocean-950 text-white px-3 py-1.5 rounded transition-colors">Book Now</a>
      </div>
    </div>

    <% ratingRows.forEach((row, i) => {
      const sA = a.ratings[row.key]
      const sB = b.ratings[row.key]
      if (sA === null && sB === null) return
    %>
      <div class="ratings-row grid grid-cols-[1fr_80px_80px] sm:grid-cols-[1fr_100px_100px] border-b border-ocean-50 last:border-0 <%= i % 2 === 0 ? 'bg-white' : 'bg-ocean-50/40' %>">
        <div class="px-4 sm:px-5 py-3.5 font-sans text-sm text-ocean-700 font-medium flex items-center gap-2">
          <%= row.label %>
          <% if (row.key === 'overall') { %>
            <span class="text-[10px] font-bold uppercase tracking-wider text-ocean-400 bg-ocean-100 px-1.5 py-0.5 rounded">Overall</span>
          <% } %>
        </div>
        <div class="py-3.5 flex items-center justify-center">
          <% if (sA !== null) { %>
            <span class="font-sans text-base font-bold tabular-nums <%= scoreColor(sA) %>"><%= sA %></span>
          <% } else { %>
            <span class="text-gray-300">—</span>
          <% } %>
        </div>
        <div class="py-3.5 flex items-center justify-center">
          <% if (sB !== null) { %>
            <span class="font-sans text-base font-bold tabular-nums <%= scoreColor(sB) %>"><%= sB %></span>
          <% } else { %>
            <span class="text-gray-300">—</span>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Verdict (hidden when 3+ resorts) -->
  <div id="verdict-section" class="bg-ocean-950 rounded-2xl p-6 sm:p-8 mb-6">
    <p class="font-sans text-xs font-bold uppercase tracking-widest text-ocean-500 mb-1">Our Verdict</p>
    <h2 class="font-serif text-2xl font-bold text-white mb-3"><%= winner.name %> comes out ahead</h2>
    <p class="font-sans text-ocean-300 leading-relaxed text-sm">
      <%= winner.name %> scores <%= winner.ratings.overall %>/10 overall vs <%= loser.ratings.overall %>/10 for <%= loser.name %>.
      <% if (winner.ratings.value !== null && loser.ratings.value !== null) { %>
        <% if (winner.ratings.value >= loser.ratings.value) { %>
          It also leads on value (<%= winner.ratings.value %> vs <%= loser.ratings.value %>), making it the stronger pick for most travelers.
        <% } else { %>
          However, <%= loser.name %> scores higher on value (<%= loser.ratings.value %> vs <%= winner.ratings.value %>), so budget-focused travelers may prefer it.
        <% } %>
      <% } %>
    </p>
    <div class="mt-5 flex flex-col sm:flex-row gap-3">
      <a href="<%= winner.agodaLink %>" target="_blank" rel="noopener noreferrer sponsored" class="flex-1 text-center font-sans text-sm font-bold bg-gold-500 hover:bg-gold-600 text-white rounded-xl py-3 transition-colors">Check Prices — <%= winner.name.split(' ').slice(0, 2).join(' ') %> →</a>
      <a href="<%= loser.agodaLink %>" target="_blank" rel="noopener noreferrer sponsored" class="flex-1 text-center font-sans text-sm font-semibold bg-white/10 hover:bg-white/20 text-white rounded-xl py-3 transition-colors">Check Prices — <%= loser.name.split(' ').slice(0, 2).join(' ') %> →</a>
    </div>
  </div>

  <!-- More comparisons -->
  <div class="bg-white border border-ocean-100 rounded-2xl p-5 sm:p-6 shadow-card">
    <h2 class="font-serif text-lg font-bold text-ocean-950 mb-4">More Comparisons</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      <% resorts.filter(r => r.slug !== a.slug && r.slug !== b.slug).forEach(r => { %>
        <a href="<%= pairUrl(a.slug, r.slug) %>" class="font-sans text-sm text-ocean-700 hover:text-ocean-950 hover:underline transition-colors py-0.5"><%= a.name %> vs <%= r.name %> →</a>
        <a href="<%= pairUrl(b.slug, r.slug) %>" class="font-sans text-sm text-ocean-700 hover:text-ocean-950 hover:underline transition-colors py-0.5"><%= b.name %> vs <%= r.name %> →</a>
      <% }) %>
    </div>
  </div>

</div>

<!-- Add Resort modal -->
<div id="add-resort-modal" class="hidden fixed inset-0 z-50 bg-black/60 flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-md shadow-2xl">
    <div class="flex items-center justify-between px-5 py-4 border-b border-ocean-100">
      <h3 class="font-serif text-lg font-bold text-ocean-950">Add a Resort to Compare</h3>
      <button type="button" id="add-resort-close" class="text-ocean-400 hover:text-ocean-900 text-xl leading-none">×</button>
    </div>
    <form id="add-resort-form" class="p-5 space-y-3">
      <select id="add-country" class="w-full font-sans text-sm bg-white border border-ocean-200 text-ocean-900 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-ocean-500">
        <option value="">Select country</option>
      </select>
      <select id="add-area" disabled class="w-full font-sans text-sm bg-white border border-ocean-200 text-ocean-900 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-ocean-500 disabled:opacity-40 hidden">
        <option value="">Select region / area</option>
      </select>
      <select id="add-resort" disabled class="w-full font-sans text-sm bg-white border border-ocean-200 text-ocean-900 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-ocean-500 disabled:opacity-40">
        <option value="">Select resort</option>
      </select>
      <button type="submit" id="add-resort-submit" disabled class="w-full font-sans text-sm font-bold bg-ocean-900 hover:bg-ocean-950 disabled:bg-ocean-300 text-white rounded-xl py-3 transition-colors">Add to Comparison</button>
    </form>
  </div>
</div>

<script id="pair-data" type="application/json">
<%- JSON.stringify({
  base: [a.slug, b.slug],
  resorts: resorts.map(r => ({
    slug: r.slug, name: r.name, country: r.country, area: r.area, type: r.type,
    ratings: r.ratings, amenities: r.amenities, agodaLink: r.agodaLink,
  })),
  ratingRows,
}) %>
</script>
<script src="/compare-pair.js" defer></script>
