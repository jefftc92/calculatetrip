<div class="bg-ocean-950 pt-10 pb-16 px-4 sm:px-6">
  <div class="max-w-5xl mx-auto">
    <nav class="flex items-center gap-2 text-xs text-ocean-400 mb-4">
      <a href="/" class="hover:text-ocean-200">Home</a>
      <span>·</span>
      <span class="text-ocean-300">Compare Resorts</span>
    </nav>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-white">Compare Resorts</h1>
    <p class="font-sans text-ocean-400 mt-2 max-w-lg text-sm">Side-by-side ratings, amenities, and our editorial verdict for any two all-inclusive resorts.</p>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 sm:px-6 -mt-6 pb-16">

  <!-- Picker: works without JS via native form submit. Vanilla JS upgrades it. -->
  <div class="bg-white border border-ocean-100 rounded-2xl shadow-card p-6 mb-12" id="compare-picker-root">
    <p class="font-sans text-sm text-ocean-500 mb-5">Pick any two resorts to compare side by side.</p>
    <form id="compare-form" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] gap-3 items-center">
        <div>
          <label class="block font-sans text-xs font-bold uppercase tracking-widest text-ocean-500 mb-1.5">Resort A</label>
          <select name="a" id="resort-a" required class="w-full font-sans text-sm bg-white border border-ocean-200 text-ocean-900 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-ocean-500">
            <option value="">Select a resort</option>
            <% resorts.forEach(r => { %>
              <option value="<%= r.slug %>"><%= r.name %></option>
            <% }) %>
          </select>
        </div>
        <span class="font-sans text-sm font-bold text-ocean-400 text-center sm:mt-7">vs</span>
        <div>
          <label class="block font-sans text-xs font-bold uppercase tracking-widest text-ocean-500 mb-1.5">Resort B</label>
          <select name="b" id="resort-b" required class="w-full font-sans text-sm bg-white border border-ocean-200 text-ocean-900 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-ocean-500">
            <option value="">Select a resort</option>
            <% resorts.forEach(r => { %>
              <option value="<%= r.slug %>"><%= r.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
      <button type="submit" class="w-full font-sans text-sm font-bold bg-ocean-900 hover:bg-ocean-950 text-white rounded-xl py-3 transition-colors">Compare Resorts →</button>
      <p id="compare-error" class="hidden font-sans text-sm text-red-600"></p>
    </form>
  </div>
  <script src="/compare-picker.js" defer></script>

  <!-- Pre-rendered link list: this is what Google indexes -->
  <h2 class="font-serif text-2xl font-bold text-ocean-950 mb-5">Popular Comparisons</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 mb-14">
    <% pairs.forEach(({ a, b }) => { %>
      <a href="<%= pairUrl(a.slug, b.slug) %>" class="flex items-center gap-2.5 py-3 border-b border-ocean-100 font-sans text-sm text-ocean-700 hover:text-ocean-950 group transition-colors">
        <span class="text-ocean-400 group-hover:text-ocean-600 transition-colors shrink-0">→</span>
        <span><%= a.name %> vs <%= b.name %></span>
      </a>
    <% }) %>
  </div>

  <div class="mb-12 max-w-2xl">
    <h2 class="font-serif text-2xl font-bold text-ocean-950 mb-3">About Our Compare Tool</h2>
    <p class="font-sans text-sm text-ocean-600 leading-relaxed">
      We aggregate verified guest reviews from major booking platforms to score every resort across eleven categories: food, beach, pool, atmosphere, location, rooms, value, cleanliness, service, and sleep quality. The overall score is a weighted composite designed to reflect the full experience — not just the highlights. Pick any two resorts above to see a full side-by-side breakdown, amenities checklist, and our editorial verdict. Affiliate links are disclosed and never influence ratings.
    </p>
  </div>

  <h2 class="font-serif text-2xl font-bold text-ocean-950 mb-2">FAQs</h2>
  <div class="divide-y divide-ocean-100">
    <% [
      { q: 'How do I use the compare tool?', a: 'Use the form above to pick two resorts and click "Compare Resorts." You will be taken to a side-by-side breakdown of scores, amenities, and our editorial verdict.' },
      { q: 'How many resorts can I compare at once?', a: 'The tool supports head-to-head comparisons between two resorts, covering eleven rating categories plus a full amenities checklist.' },
      { q: 'Where do the scores come from?', a: 'Scores are aggregated from verified guest reviews on major booking platforms, weighted for recency and review volume. Each category — food, beach, pool, atmosphere, location, rooms, value, cleanliness, service, and sleep quality — is scored independently out of 10.' },
      { q: 'Are these resorts truly all-inclusive?', a: 'Yes — every resort in our database is verified all-inclusive. Core inclusions (accommodation, meals, drinks, core activities) are confirmed before listing. Some premium extras like spa treatments or specialty restaurants may carry additional charges.' },
      { q: 'How current is the data?', a: 'Resort scores are reviewed continuously and reflect the most current available guest review aggregates.' },
    ].forEach(faq => { %>
      <details class="group py-4">
        <summary class="flex items-center justify-between cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none">
          <span class="font-sans text-sm font-semibold text-ocean-900 pr-4"><%= faq.q %></span>
          <span class="text-ocean-400 text-sm shrink-0 group-open:rotate-180 transition-transform inline-block">▾</span>
        </summary>
        <p class="font-sans text-sm text-ocean-600 leading-relaxed mt-2 max-w-2xl"><%= faq.a %></p>
      </details>
    <% }) %>
  </div>

</div>
