<footer class="bg-ocean-950 text-ocean-400 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 grid grid-cols-2 md:grid-cols-4 gap-8">
    <div class="col-span-2">
      <p class="font-serif font-bold text-lg text-white tracking-tight"><%= SITE_NAME %></p>
      <p class="font-sans text-xs uppercase tracking-widest text-ocean-500 mt-1">All-Inclusive Guide</p>
      <p class="font-sans text-sm mt-4 max-w-sm">Independent ratings and reviews for the best all-inclusive resorts in the Caribbean and Latin America.</p>
    </div>
    <div>
      <p class="font-sans text-xs font-bold uppercase tracking-widest text-ocean-300 mb-3">Explore</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/resorts/" class="hover:text-white transition-colors">All Resorts</a></li>
        <li><a href="/compare/" class="hover:text-white transition-colors">Compare Resorts</a></li>
        <li><a href="/best-value-all-inclusive-resorts/" class="hover:text-white transition-colors">Best Value</a></li>
        <li><a href="/best-beach-all-inclusive-resorts/" class="hover:text-white transition-colors">Best Beach</a></li>
      </ul>
    </div>
    <div>
      <p class="font-sans text-xs font-bold uppercase tracking-widest text-ocean-300 mb-3">By Style</p>
      <ul class="space-y-2 text-sm">
        <li><a href="/best-adults-only-all-inclusive-resorts/" class="hover:text-white transition-colors">Adults Only</a></li>
        <li><a href="/best-family-all-inclusive-resorts/" class="hover:text-white transition-colors">Family</a></li>
        <% countries.forEach(c => { %>
          <li><a href="/destination/<%= c.slug %>/" class="hover:text-white transition-colors"><%= c.name %></a></li>
        <% }) %>
      </ul>
    </div>
  </div>
  <div class="border-t border-ocean-900 px-4 sm:px-6 py-6 max-w-7xl mx-auto flex flex-col sm:flex-row justify-between gap-2 text-xs">
    <span>© <%= new Date().getFullYear() %> <%= SITE_NAME %>. All rights reserved.</span>
    <span>Affiliate links disclosed and never influence ratings.</span>
  </div>
</footer>
